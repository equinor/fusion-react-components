{
  "name": "@equinor/fusion-react-components",
  "version": "1.1.3",
  "description": "Fusion React Components is a library of React components for building user interfaces in Fusion",
  "keywords": [
    "react",
    "components",
    "fusion",
    "equinor",
    "library"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./person": {
      "import": "./dist/person.js",
      "types": "./dist/person.d.ts"
    },
    "./package.json": "./package.json",
    "./README.md": "./README.md",
    "./CHANGELOG.md": "./CHANGELOG.md"
  },
  "homepage": "https://github.com/equinor/fusion-react-components/blob/main/components#readme",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "dist": "dist"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/equinor/fusion-react-components.git",
    "directory": "components"
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "biome lint",
    "format": "biome format",
    "prepack": "npm run build"
  },
  "bugs": {
    "url": "https://github.com/equinor/fusion-react-components/issues"
  },
  "dependencies": {
    "@equinor/fusion-react-person": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.5"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  }
}
